# PayPal API Credentials
# Get these from https://developer.paypal.com/dashboard/applications

# Your PayPal REST API Client ID
PAYPAL_CLIENT_ID=your_client_id_here

# Your PayPal REST API Client Secret
PAYPAL_CLIENT_SECRET=your_client_secret_here

# Environment: 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox

# Webhook ID (optional but recommended for security)
# Get this from your PayPal app webhook settings
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# Optional: Custom redirect URLs
# PAYPAL_RETURN_URL=https://your-domain.com/payment/success
# PAYPAL_CANCEL_URL=https://your-domain.com/payment/cancel
